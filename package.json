{
  "name": "@cascateer/eslint",
  "version": "0.0.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cascateer/eslint.git"
  },
  "scripts": {
    "semver-patch": "npm version patch && git push origin main --tags",

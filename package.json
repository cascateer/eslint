  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@smarttools/eslint-plugin-rxjs": "^1.0.22",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependencies": {
    "eslint": ">=9"
  }
}
